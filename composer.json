{
    "name": "marko/database",
    "description": "Marko Framework Database Layer - Entity-driven schema with Data Mapper pattern",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "^0.1"
    },
    "repositories": [
        {
            "type": "path",
            "url": "../core"
        }
    ],
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Database\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Database\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
